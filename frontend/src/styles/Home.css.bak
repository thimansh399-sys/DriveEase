.home-container {
  width: 100%;
}

/* Hero Section */
/* Premium DriveEase Hero */
.hero {
  background: linear-gradient(135deg, #16a34a 0%, #166534 100%);
  color: #fff;
  padding: 80px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transform: perspective(1000px);
}

.hero-content {
  animation: slideInDown 0.8s ease-out;
}

.hero h1 {
  font-size: 48px;
  font-weight: bold;
  margin-bottom: 20px;
  text-shadow: 2px 8px 16px rgba(0, 0, 0, 0.3);
  letter-spacing: -1px;
}

.hero p {
  font-size: 20px;
  margin-bottom: 30px;
  opacity: 0.95;
  line-height: 1.6;
}

.hero-buttons {

  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 30px;
}

.hero-buttons .btn {
  padding: 15px 30px;
  font-size: 16px;
  font-weight: bold;
  transition: all 0.3s ease;
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
}

.hero-buttons .btn-primary {
  background: var(--primary-color, #16a34a);
  color: #fff;
  border: none;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(22,163,74,0.12);
}

.hero-buttons .btn-primary:hover {
  transform: translateY(-4px);
  background: var(--primary-dark, #166534);
}

.hero-buttons .btn-outline {
  background: transparent;
  color: var(--primary-color, #16a34a);
  border: 2px solid var(--primary-color, #16a34a);
  border-radius: 8px;
}

.hero-buttons .btn-outline:hover {
  background: rgba(22,163,74,0.08);
  color: #fff;
  border-color: var(--primary-dark, #166534);
}

/* Trust Badges */
.trust-badges {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 30px;
}

.badge {
  text-align: center;
  padding: 15px;
}

.badge-icon {

  font-size: 28px;
  margin-bottom: 10px;
}

.badge-text {
  font-size: 14px;
  color: #16a34a;
}

/* Animations */
@keyframes slideInDown {

  from {
    opacity: 0;
    transform: translateY(-50px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.features-section {
  padding: 80px 20px;
  background: #10151a;
}

.section-container {
  max-width: 1200px;
  margin: 0 auto;
}

.section-header {
  text-align: center;
  margin-bottom: 60px;
}

.section-header h2 {
  font-size: 36px;
  font-weight: 800;
  color: #ffffff;
  margin: 0 0 15px 0;
}

.section-header p {
  font-size: 16px;
  color: #6b7280;
  margin: 0;
}

.features-grid {

  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 30px;
}

.feature-card {
  background: #181f25;
  padding: 40px 30px;
  border-radius: 16px;
  text-align: center;
  box-shadow: 0 2px 12px rgba(22,163,74,0.10);
  transition: all 0.3s;
}

.feature-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
}

.feature-icon {

  font-size: 48px;
  margin-bottom: 20px;
}

.feature-card h3 {
  font-size: 20px;
  font-weight: 700;
  color: #16a34a;
  margin: 0 0 12px 0;
}

.feature-card p {
  color: #b6e7c9;
  margin: 0;
  line-height: 1.6;
}

.how-it-works-section {
  padding: 80px 20px;
  background: white;
}

.steps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 40px;
  max-width: 1200px;
  margin: 0 auto;
}

.step-card {

  text-align: center;
  position: relative;
}

.step-number {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: linear-gradient(135deg, #16a34a 0%, #166534 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 700;
  margin: 0 auto 20px;
}

.step-card h3 {
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 12px 0;
}

.step-card p {

  color: #6b7280;
  margin: 0;
}

.pricing-section {
  padding: 80px 20px;
  background: #10151a;
}

.pricing-grid {

  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  max-width: 1200px;
  margin: 0 auto;
}

.pricing-card {
  background: #181f25;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(22,163,74,0.10);
  transition: all 0.3s;
  border: 2px solid transparent;
}

.pricing-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 30px rgba(22,163,74,0.18);
  border-color: #16a34a;
}

.pricing-card.featured {

  border-color: #16a34a;
}

.pricing-header {
  background: linear-gradient(135deg, #16a34a22 0%, #16653422 100%);
  padding: 30px 20px;
  text-align: center;
}

.pricing-card h3 {
  font-size: 22px;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 10px 0;
}

.pricing-card p {
  color: #6b7280;
  margin: 0;
}

.price-display {

  text-align: center;
  padding: 30px 20px;
}

.price {
  font-size: 48px;
  font-weight: 800;
  color: #16a34a;
  margin: 0 10px 0 0;
}

.price-period {
  font-size: 14px;
  color: #6b7280;
}

.features-list {
  padding: 0 20px;
  margin-bottom: 30px;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid #f3f4f6;
  font-size: 14px;
  color: #6b7280;
}

.feature-item:last-child {

  border-bottom: none;
}

.check-icon {
  color: #16a34a;
  font-weight: bold;
}

.pricing-action {
  padding: 0 20px 30px;
}

.pricing-action .btn {
  width: 100%;
}

.testimonials-section {
  padding: 80px 20px;
  background: white;
}

.testimonials-grid {

  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  max-width: 1200px;
  margin: 0 auto;
}

.testimonial-card {
  background: #181f25;
  padding: 30px;
  border-radius: 16px;
  border-left: 4px solid #16a34a;
}

.testimonial-text {
  color: #6b7280;
  margin: 0 0 20px 0;
  line-height: 1.6;
  font-style: italic;
}

.testimonial-author {

  display: flex;
  align-items: center;
  gap: 12px;
}

.author-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #16a34a 0%, #166534 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

.author-info {
  flex: 1;
}

.author-name {
  font-weight: 600;
  color: #ffffff;
  margin: 0;
}

.author-title {
  font-size: 12px;
  color: #6b7280;
  margin: 0;
}


.cta-section {
  padding: 80px 20px;
  background: linear-gradient(135deg, #16a34a 0%, #166534 100%);
  color: #fff;
  text-align: center;
}

.cta-content {
  max-width: 600px;
  margin: 0 auto;
}

.cta-section h2 {
  font-size: 36px;
  font-weight: 800;
  margin: 0 0 20px 0;
}

.cta-section p {
  font-size: 16px;
  margin: 0 0 30px 0;
  opacity: 0.95;
}

@media (max-width: 768px) {
  .hero-section {
    padding: 50px 20px;
  }

  .hero-section h1 {
    font-size: 32px;
  }

  .hero-section p {
    font-size: 16px;
  }

  .features-section,
  .how-it-works-section,
  .pricing-section,
  .testimonials-section,
  .cta-section {
    padding: 50px 20px;
  }

  .section-header h2 {
    font-size: 28px;
  }

  .features-grid,
  .pricing-grid,
  .testimonials-grid {
    grid-template-columns: 1fr;
  }

  .cta-section h2 {
    font-size: 28px;
  }
}
