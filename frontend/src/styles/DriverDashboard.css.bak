.driver-dashboard {
  min-height: calc(100vh - 80px);
  background: #101820;
  padding: 30px 20px;
}

.driver-container {
  max-width: 1200px;
  margin: 0 auto;
}

.driver-header {
  background: rgba(30, 41, 59, 0.8);
  border-radius: 12px;
  padding: 30px;
  margin-bottom: 30px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.driver-profile {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 30px;
}

.driver-info {
  display: flex;
  gap: 20px;
  flex: 1;
}

.driver-avatar {
  width: 100px;
  height: 100px;
  border-radius: 12px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48px;
}

.driver-details h2 {
  margin: 0 0 5px 0;
  font-size: 24px;
  color: #ffffff;
}

.driver-details p {
  margin: 5px 0;
  color: #6b7280;
  font-size: 14px;
}

.rating-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #fef3c7;
  color: #92400e;
  padding: 8px 12px;
  border-radius: 6px;
  margin-top: 10px;
  font-weight: 600;
  font-size: 14px;
}

.driver-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.stat-item {
  text-align: center;
}

.stat-item .value {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 5px;
}

.stat-item .label {
  display: block;
  font-size: 12px;
  color: #6b7280;
  text-transform: uppercase;
}

.driver-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.btn {
  padding: 12px 24px;
  border: none;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(102, 126, 234, 0.3);
}

.btn-secondary {
  background: rgba(30, 41, 59, 0.5);
  color: #ffffff;
  border: 1px solid #e5e7eb;
}

.btn-secondary:hover {
  background: #e5e7eb;
}

.btn-danger {
  background: #fee2e2;
  color: #991b1b;
}

.btn-danger:hover {
  background: #fecaca;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  margin-bottom: 30px;
}

.card {
  background: rgba(30, 41, 59, 0.6);
  border-radius: 12px;
  padding: 25px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 20px 0;
  padding-bottom: 15px;
  border-bottom: 1px solid #e5e7eb;
}

.earnings-display {
  font-size: 36px;
  font-weight: 700;
  color: #10b981;
  margin-bottom: 10px;
}

.earnings-period {
  color: #6b7280;
  font-size: 14px;
  margin-bottom: 20px;
}

.earnings-breakdown {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.breakdown-item {
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid #f3f4f6;
  font-size: 14px;
}

.breakdown-item:last-child {
  border-bottom: none;
}

.breakdown-label {
  color: #6b7280;
}

.breakdown-value {
  font-weight: 600;
  color: #ffffff;
}

.trips-list {
  max-height: 500px;
  overflow-y: auto;
}

.trip-item {
  padding: 15px;
  background: rgba(30, 41, 59, 0.5);
  border-radius: 8px;
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.trip-info {
  flex: 1;
}

.trip-route {
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 5px;
}

.trip-time {
  font-size: 13px;
  color: #6b7280;
}

.trip-amount {
  font-weight: 700;
  color: #10b981;
  font-size: 16px;
}

.trip-status {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 600;
  background: #d1fae5;
  color: #065f46;
  margin-left: 15px;
}

.documents-section {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 15px;
}

.document-item {
  border: 2px dashed #e5e7eb;
  border-radius: 8px;
  padding: 20px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
}

.document-item:hover {
  border-color: #667eea;
  background: #101820;
}

.document-icon {
  font-size: 32px;
  margin-bottom: 10px;
}

.document-name {
  font-size: 13px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 5px;
}

.document-status {
  font-size: 12px;
  color: #6b7280;
}

.verified {
  color: #10b981;
}

.pending {
  color: #f59e0b;
}

.schedule-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

.availability-toggle {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 15px;
  background: #101820;
  border-radius: 8px;
}

.toggle-switch {
  position: relative;
  width: 50px;
  height: 28px;
}

.toggle-switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.toggle-slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ccc;
  transition: 0.3s;
  border-radius: 28px;
}

.toggle-slider:before {
  position: absolute;
  content: '';
  height: 22px;
  width: 22px;
  left: 3px;
  bottom: 3px;
  background-color: white;
  transition: 0.3s;
  border-radius: 50%;
}

input:checked + .toggle-slider {
  background-color: #10b981;
}

input:checked + .toggle-slider:before {
  transform: translateX(22px);
}

@media (max-width: 1024px) {
  .driver-profile {
    flex-direction: column;
    gap: 20px;
  }

  .driver-stats {
    grid-template-columns: repeat(2, 1fr);
  }

  .schedule-section {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .driver-dashboard {
    padding: 20px 15px;
  }

  .driver-header {
    padding: 20px;
  }

  .driver-info {
    flex-direction: column;
  }

  .driver-header {
    margin-bottom: 20px;
  }

  .dashboard-grid {
    grid-template-columns: 1fr;
  }

  .driver-actions {
    flex-direction: column;
  }

  .btn {
    width: 100%;
  }
}
