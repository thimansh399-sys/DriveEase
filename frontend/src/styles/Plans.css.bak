.plans-container {
  max-width: 900px;
  margin: 40px auto;
  padding: 24px;
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.08);
}

.plans-title {
  text-align: center;
  font-size: 2.2rem;
  margin-bottom: 32px;
  color: #2d3a4b;
}

.plans-list {
  display: flex;
  gap: 32px;
  justify-content: center;
  flex-wrap: wrap;
}

.plan-card {
  background: linear-gradient(135deg, #e0e7ff 0%, #f0f4ff 100%);
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(44,62,80,0.07);
  padding: 28px 24px;
  min-width: 240px;
  max-width: 300px;
  flex: 1 1 260px;
  text-align: center;
  transition: transform 0.2s;
}
.plan-card:hover {
  transform: translateY(-8px) scale(1.03);
  box-shadow: 0 8px 32px rgba(44,62,80,0.13);
}
.plan-price {
  font-size: 1.6rem;
  color: #3b82f6;
  margin: 12px 0 4px 0;
  font-weight: bold;
}
.plan-duration {
  color: #64748b;
  font-size: 1rem;
  margin-bottom: 16px;
}
.plan-features {
  list-style: none;
  padding: 0;
  margin: 0;
}
.plan-features li {
  margin: 8px 0;
  color: #e0e0e0;
  font-size: 1rem;
}
