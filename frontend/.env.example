# Frontend Environment Variables

# API Configuration
# For local development: http://localhost:5000/api
# For production: https://your-backend-service.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api

# Authentication
REACT_APP_JWT_SECRET_STORAGE_KEY=driveease_token

# Payment Keys (optional)
REACT_APP_RAZORPAY_KEY=your_razorpay_key_here
REACT_APP_UPI_ID=your_upi_id@bankname

# Google Maps (optional)
REACT_APP_GOOGLE_KEY=your_google_maps_api_key

# Environment
REACT_APP_ENV=development
